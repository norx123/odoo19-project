<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_sign_settings" model="ir.actions.act_window">
        <field name="name">Sign Settings</field>
        <field name="res_model">sign.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record>

    <record id="view_sign_settings_form" model="ir.ui.view">
        <field name="name">sign.config.settings.form</field>
        <field name="model">sign.config.settings</field>
        <field name="arch" type="xml">
            <form string="Sign Settings">
                <sheet>
                    <div class="oe_title">
                        <h1>Sign Module Settings</h1>
                    </div>

                    <group string="General">
                        <field name="sign_default_terms"/>
                        <field name="sign_manage_template_access"/>
                    </group>

                    <group string="Integrations">
                        <field name="sign_aadhaar"/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_save" string="Save"
                            type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
