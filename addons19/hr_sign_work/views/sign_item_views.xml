<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- ACTION                                                 -->
    <!-- ===================================================== -->

    <record id="action_sign_item" model="ir.actions.act_window">
        <field name="name">Sign Items</field>
        <field name="res_model">sign.item</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- ===================================================== -->
    <!-- LIST VIEW                                              -->
    <!-- ===================================================== -->

    <record id="view_sign_item_list" model="ir.ui.view">
        <field name="name">sign.item.list</field>
        <field name="model">sign.item</field>
        <field name="arch" type="xml">
            <list string="Sign Items">

                <field name="template_id"/>
                <field name="name"/>
                <field name="type_id"/>
                <field name="responsible"/>

                <field name="page"/>
                <field name="pos_x"/>
                <field name="pos_y"/>

                <field name="width"/>
                <field name="height"/>

                <field name="required"/>

            </list>
        </field>
    </record>


    <!-- ===================================================== -->
    <!-- FORM VIEW                                              -->
    <!-- ===================================================== -->

    <record id="view_sign_item_form" model="ir.ui.view">
        <field name="name">sign.item.form</field>
        <field name="model">sign.item</field>
        <field name="arch" type="xml">
            <form string="Sign Item">

                <sheet>

                    <group>
                        <group>
                            <field name="template_id"/>
                            <field name="name" readonly="1"/>
                            <field name="type_id"/>
                            <field name="responsible"/>
                            <field name="required"/>
                        </group>

                        <group string="PDF Position">
                            <field name="page"/>
                            <field name="pos_x"/>
                            <field name="pos_y"/>
                            <field name="width"/>
                            <field name="height"/>
                        </group>
                    </group>

                </sheet>

            </form>
        </field>
    </record>

</odoo>