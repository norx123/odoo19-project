<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_sign_doc" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">custom.sign.doc</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_sign_doc_list" model="ir.ui.view">
        <field name="name">sign.doc.list</field>
        <field name="model">custom.sign.doc</field>
        <field name="arch" type="xml">
            <list string="Documents">
                <field name="name" string="Document Name"/>
                <field name="user_id" string="Created By" widget="many2one_avatar_user"/>
                <field name="tag_ids" widget="many2many_tags" optional="show"/>
                <field name="write_date" widget="datetime" optional="show"/>
                <field name="last_shared" optional="show"/>
                <field name="shared_with_ids" widget="many2many_tags" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_sign_doc_form" model="ir.ui.view">
        <field name="name">sign.doc.form</field>
        <field name="model">custom.sign.doc</field>
        <field name="arch" type="xml">
            <form string="Document" class="o_sign_doc_form">
                <header>
                    <button name="action_share" string="Share"
                            type="object" class="btn-primary"/>
                    <field name="last_shared" readonly="1" invisible="not last_shared"/>
                </header>
                <sheet class="o_sign_doc_sheet">

                    <div class="o_sign_doc_title_wrap">
                        <field name="name"
                               placeholder="Untitled document"
                               class="o_sign_doc_title"
                               nolabel="1"/>
                    </div>

                    <div class="o_sign_doc_meta">
                        <field name="user_id" widget="many2one_avatar_user" readonly="1" nolabel="1"/>
                        <field name="tag_ids" widget="many2many_tags" nolabel="1" placeholder="Add tags..."/>
                    </div>

                    <div class="o_sign_doc_page_wrap">
                        <div class="o_sign_doc_page">
                            <field name="content"
                                   widget="html"
                                   nolabel="1"
                                   class="o_sign_doc_editor"
                                   placeholder="Start typing..."
                                   options="{'collaborative': false}"/>
                        </div>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sign_doc_share_wizard_form" model="ir.ui.view">
        <field name="name">sign.doc.share.wizard.form</field>
        <field name="model">custom.sign.doc.share.wizard</field>
        <field name="arch" type="xml">
            <form string="Share Document">
                <sheet>
                    <div class="o_sign_share_link_box">
                        <label for="share_link" string="Share Link"/>
                        <field name="share_link" readonly="1" class="o_sign_share_link_input"/>
                    </div>
                    <group>
                        <field name="doc_id" readonly="1"/>
                        <field name="partner_ids" widget="many2many_tags" string="Share With"/>
                        <field name="note" string="Message"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_done" string="Done"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
