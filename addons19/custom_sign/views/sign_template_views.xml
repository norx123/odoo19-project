<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- ACTION -->
    <!-- ===================================================== -->

    <record id="action_sign_template" model="ir.actions.act_window">
        <field name="name">Templates</field>
        <field name="res_model">custom.sign.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Sign Template
            </p>
            <p>
                Upload a PDF, drag field placeholders onto it,
                and send it to people for signing.
            </p>
        </field>
    </record>


    <!-- ===================================================== -->
    <!-- FORM VIEW -->
    <!-- ===================================================== -->

    <record id="view_sign_template_form" model="ir.ui.view">
        <field name="name">sign.template.form</field>
        <field name="model">custom.sign.template</field>
        <field name="arch" type="xml">

            <form string="Sign Template" class="o_sign_template_form">

                <header>
                    <button name="action_send"     string="Send"     type="object" class="btn-primary"/>
                    <button name="action_sign_now" string="Sign Now" type="object" class="btn-primary"/>
                    <button name="action_share"    string="Share"    type="object" class="btn-secondary"/>
                </header>

                <sheet>

                    <!-- Breadcrumb -->
                    <div class="o_sign_breadcrumb_bar">
                        <a class="o_sign_breadcrumb_link" href="/odoo/sign">
                            <i class="fa fa-th-large"/> Sign
                        </a>
                        <span class="o_sign_breadcrumb_sep">/</span>
                        <a class="o_sign_breadcrumb_link" href="#" data-menu-xmlid="custom_sign.menu_sign_templates">
                            Templates
                        </a>
                        <span class="o_sign_breadcrumb_sep">/</span>
                        <span class="o_sign_breadcrumb_current">
                            <field name="name" placeholder="Document name" nolabel="1"/>
                        </span>
                        <field name="is_favorite" widget="boolean_favorite" nolabel="1" style="margin-left:auto;"/>
                    </div>

                    <field name="document_name" invisible="1"/>
                    <field name="user_id" invisible="1"/>

                    <div class="o_sign_editor_wrap">

                        <!-- Sidebar -->
                        <div class="o_sign_sidebar">

                            <div>
                                <div class="o_sign_sidebar_label">Document</div>
                                <div class="o_sign_upload_area">
                                    <field name="document"
                                           filename="document_name"
                                           widget="binary"
                                           style="width:100%;"/>
                                </div>
                            </div>

                            <div>
                                <div class="o_sign_sidebar_label">Tags</div>
                                <field name="tag_ids" widget="many2many_tags"
                                       options="{'color_field': 'color', 'no_create_edit': False}"
                                       placeholder="Add tags..."/>
                            </div>

                            <div>
                                <div class="o_sign_sidebar_label">Fields</div>
                                <div class="o_sign_field_list">
                                    <div style="color:#999;font-size:12px;padding:8px;">
                                        Loading...
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- PDF area -->
                        <div class="o_sign_pdf_area">
                            <div id="o_sign_pdf_canvas">

                                <div id="o_sign_pdf_placeholder" class="o_sign_placeholder">
                                    <div class="icon">PDF</div>
                                    <div class="title">No PDF uploaded yet</div>
                                    <div class="sub">Upload a PDF from the sidebar to preview it and place fields.</div>
                                </div>

                            </div>
                        </div>

                    </div>

                    <!-- Hidden list of sign items (for the framework) -->
                    <field name="sign_item_ids" invisible="1">
                        <list>
                            <field name="type_id"/>
                            <field name="page"/>
                            <field name="pos_x"/>
                            <field name="pos_y"/>
                            <field name="width"/>
                            <field name="height"/>
                        </list>
                    </field>

                </sheet>

            </form>

        </field>
    </record>


    <!-- ===================================================== -->
    <!-- KANBAN VIEW -->
    <!-- ===================================================== -->

    <record id="view_sign_template_kanban" model="ir.ui.view">
        <field name="name">sign.template.kanban</field>
        <field name="model">custom.sign.template</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="sign_count"/>
                <field name="in_progress_count"/>
                <field name="is_favorite"/>
                <field name="sign_item_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click" style="padding:12px;">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                                <strong style="font-size:14px;"><field name="name"/></strong>
                                <field name="is_favorite" widget="boolean_favorite" nolabel="1"/>
                            </div>
                            <div class="mt-2" style="display:flex;gap:4px;flex-wrap:wrap;">
                                <span class="badge bg-success">Signed: <field name="sign_count"/></span>
                                <span class="badge bg-warning">In Progress: <field name="in_progress_count"/></span>
                                <span class="badge bg-info">Fields: <field name="sign_item_count"/></span>
                            </div>
                            <div class="mt-2">
                                <button name="action_send"     type="object" class="btn btn-sm btn-primary">Send</button>
                                <button name="action_sign_now" type="object" class="btn btn-sm btn-secondary ms-1">Sign Now</button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- ===================================================== -->
    <!-- LIST VIEW -->
    <!-- ===================================================== -->

    <record id="view_sign_template_list" model="ir.ui.view">
        <field name="name">sign.template.list</field>
        <field name="model">custom.sign.template</field>
        <field name="arch" type="xml">
            <list string="Sign Templates">

                <field name="is_favorite" widget="boolean_favorite" nolabel="1"/>
                <field name="name"/>
                <field name="tag_ids" widget="many2many_tags" optional="show"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="create_date" widget="datetime" optional="show"/>
                <field name="signee_count" string="Signees"/>
                <field name="sign_request_count" string="Documents"/>
                <field name="sign_item_count" string="Fields"/>
                <field name="sign_count" string="Signed"/>

            </list>
        </field>
    </record>


    <!-- ===================================================== -->
    <!-- (Search view: using Odoo's auto-generated default)   -->
    <!-- ===================================================== -->

</odoo>
