<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- ACTIONS -->
    <!-- ===================================================== -->

    <record id="action_sign_request" model="ir.actions.act_window">
        <field name="name">My Documents</field>
        <field name="res_model">custom.sign.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('sent_by','=',uid)]</field>
    </record>

    <record id="action_sign_request_all" model="ir.actions.act_window">
        <field name="name">All Documents</field>
        <field name="res_model">custom.sign.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
    </record>


    <!-- ===================================================== -->
    <!-- SEARCH -->
    <!-- ===================================================== -->

    <!-- ===================================================== -->
    <!-- (Search view: using Odoo's auto-generated default)   -->
    <!-- ===================================================== -->


    <!-- ===================================================== -->
    <!-- LIST -->
    <!-- ===================================================== -->

    <record id="view_sign_request_list" model="ir.ui.view">
        <field name="name">sign.request.list</field>
        <field name="model">custom.sign.request</field>
        <field name="arch" type="xml">
            <list string="Documents"
                  decoration-success="state == 'signed'"
                  decoration-info="state == 'sent'"
                  decoration-muted="state == 'draft'">

                <field name="date" widget="date"/>
                <field name="name"/>
                <field name="template_id" optional="show"/>
                <field name="sent_by" widget="many2one_avatar_user"/>
                <field name="signer_partner_ids" widget="many2many_avatar" string="Signers"/>
                <field name="tag_ids" widget="many2many_tags" optional="show"/>

                <field name="state" widget="badge"
                       decoration-success="state == 'signed'"
                       decoration-warning="state == 'sent'"
                       decoration-muted="state == 'draft'"/>

            </list>
        </field>
    </record>


    <!-- ===================================================== -->
    <!-- FORM -->
    <!-- ===================================================== -->

    <record id="view_sign_request_form" model="ir.ui.view">
        <field name="name">sign.request.form</field>
        <field name="model">custom.sign.request</field>
        <field name="arch" type="xml">
            <form string="Sign Request">

                <header>
                    <button name="action_send" type="object"
                            string="Send" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_open_sign" type="object"
                            string="Sign Now" class="btn-primary"
                            invisible="state != 'sent'"/>
                    <button name="action_download" type="object"
                            string="Download" class="btn-secondary"
                            invisible="state != 'signed'"/>
                    <button name="action_resend" type="object"
                            string="Resend" class="btn-secondary"
                            invisible="state != 'sent'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel" class="btn-secondary"
                            invisible="state in ['signed', 'cancel']"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,sent,signed"/>
                </header>

                <sheet>

                    <div class="oe_title">
                        <label for="name" string="Document"/>
                        <h1><field name="name" placeholder="Document Name"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="template_id"/>
                            <field name="sent_by" widget="many2one_avatar_user"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="valid_until"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="signed_pdf_name" invisible="not signed_pdf"/>
                            <field name="signed_pdf" filename="signed_pdf_name"
                                   invisible="not signed_pdf" readonly="1"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Signers">
                            <field name="signer_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'signed'"
                                           decoration-warning="state == 'sent'"
                                           decoration-muted="state == 'draft'"/>
                                    <field name="signing_date"/>
                                </list>
                            </field>
                        </page>

                        <page string="Filled Fields" invisible="state == 'draft'">
                            <field name="sign_item_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="item_type"/>
                                    <field name="page"/>
                                    <field name="value"/>
                                    <field name="required"/>
                                </list>
                            </field>
                        </page>

                    </notebook>

                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

</odoo>
