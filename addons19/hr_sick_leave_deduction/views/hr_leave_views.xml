<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_hr_leave_form_inherit_sick_leave"
            model="ir.ui.view">

        <field name="name">
            hr.leave.form.inherit.sick.leave
        </field>

        <field name="model">hr.leave</field>

        <field name="inherit_id"
               ref="hr_holidays.hr_leave_view_form"/>

        <field name="arch" type="xml">

            <xpath expr="//field[@name='holiday_status_id']"
                   position="after">

                <field name="show_leave_deduct"
                       invisible="1"/>

                <field name="no_of_leave_deduct"
                       invisible="show_leave_deduct == False"/>

            </xpath>

        </field>

    </record>

</odoo>
