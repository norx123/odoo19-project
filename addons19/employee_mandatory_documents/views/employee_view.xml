<odoo>
    <record id="view_employee_form_documents" model="ir.ui.view">
        <field name="name">employee.documents.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Mandatory Documents">

                    <group string="Identity Documents" col="4">
                        <field name="aadhar_number"/>
                        <field name="aadhar_file"/>
                        <field name="aadhar_issue_date"/>
                        <field name="aadhar_expiry_date"/>

                        <field name="pan_number"/>
                        <field name="pan_file"/>

                        <field name="passport_number"/>
                        <field name="passport_file"/>
                        <field name="passport_issue_date"/>
                        <field name="passport_expiry_date"/>

                        <field name="driving_license"/>
                        <field name="driving_file"/>
                        <field name="driving_issue_date"/>
                        <field name="driving_expiry_date"/>
                    </group>

                    <group string="Address Proof">
                        <field name="address_proof_type"/>
                        <field name="address_proof_file"/>
                    </group>

                    <group string="Education Documents" col="4">
                        <field name="tenth_certificate"/>
                        <field name="tenth_board"/>
                        <field name="tenth_year"/>

                        <field name="twelfth_certificate"/>
                        <field name="twelfth_board"/>
                        <field name="twelfth_year"/>

                        <field name="graduation_certificate"/>
                        <field name="graduation_university"/>
                        <field name="graduation_year"/>

                        <field name="post_graduation_certificate"/>
                    </group>

                    <group string="Bank Details" col="4">
                        <field name="bank_account"/>
                        <field name="bank_name"/>
                        <field name="ifsc_code"/>
                        <field name="branch_name"/>
                        <field name="bank_proof"/>
                    </group>

                    <group string="Employment Documents">
                        <field name="resume"/>
                        <field name="offer_letter"/>
                        <field name="appointment_letter"/>
                        <field name="experience_letter"/>
                        <field name="relieving_letter"/>
                    </group>

                    <group string="Verification">
                        <field name="document_status"/>
                        <field name="remarks"/>
                    </group>

                </page>
            </xpath>
        </field>
    </record>
</odoo>
