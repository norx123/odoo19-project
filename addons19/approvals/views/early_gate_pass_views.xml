<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================================
         EARLY LOGOUT GATE PASS VIEWS
         ============================================================ -->

    <!-- Form View -->
    <record id="view_early_gate_pass_form" model="ir.ui.view">
        <field name="name">approvals.early.gate.pass.form</field>
        <field name="model">approvals.early.gate.pass</field>
        <field name="arch" type="xml">
            <form string="Early Logout Gate Pass">
                <header>
                    <button name="action_submit" string="Submit"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager,hr.group_hr_user"/>
                    <button name="action_refuse" string="Refuse"
                            type="object"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager,hr.group_hr_user"/>
                    <button name="action_print_gate_pass" string="Download Gate Pass"
                            type="object" class="btn-success"
                            invisible="state != 'approved'"
                            icon="fa-download"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state not in ('draft', 'submitted')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('refused', 'cancel')"
                            groups="hr.group_hr_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Employee Information">
                            <field name="employee_id"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="employee_code" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="manager_id"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="company_id"
                                   readonly="state in ('approved', 'refused', 'cancel')"
                                   groups="base.group_multi_company"/>
                        </group>
                        <group string="Logout Details">
                            <field name="request_date"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="login_time" widget="float_time"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="logout_time" widget="float_time"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="duration_hours" widget="float_time" readonly="1"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"
                               placeholder="Provide the reason for early logout..."
                               readonly="state in ('approved', 'refused', 'cancel')"/>
                    </group>
                    <notebook>
                        <page string="Approver(s)" name="approvers">
                            <field name="approver_ids"
                                   readonly="state in ('approved', 'refused', 'cancel')">
                                <list editable="bottom">
                                    <field name="approver_id" string="Approver"/>
                                    <field name="required" string="Required"/>
                                    <field name="status" string="Status" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_early_gate_pass_list" model="ir.ui.view">
        <field name="name">approvals.early.gate.pass.list</field>
        <field name="model">approvals.early.gate.pass</field>
        <field name="arch" type="xml">
            <list string="Early Logout Gate Pass"
                  decoration-success="state == 'approved'"
                  decoration-warning="state == 'submitted'"
                  decoration-danger="state == 'refused'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="employee_code"/>
                <field name="department_id"/>
                <field name="manager_id"/>
                <field name="request_date"/>
                <field name="login_time" widget="float_time"/>
                <field name="logout_time" widget="float_time"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'submitted'"
                       decoration-danger="state == 'refused'"
                       decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_early_gate_pass_search" model="ir.ui.view">
        <field name="name">approvals.early.gate.pass.search</field>
        <field name="model">approvals.early.gate.pass</field>
        <field name="arch" type="xml">
            <search string="Search Early Logout Gate Pass">
                <field name="name" string="Reference"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <filter string="My Requests" name="my_requests"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft"
                        domain="[('state','=','draft')]"/>
                <filter string="Submitted" name="submitted"
                        domain="[('state','=','submitted')]"/>
                <filter string="Approved" name="approved"
                        domain="[('state','=','approved')]"/>
                <filter string="Refused" name="refused"
                        domain="[('state','=','refused')]"/>
                <separator/>
                <filter string="Employee" name="group_employee" domain="[]"
                        context="{'group_by': 'employee_id'}"/>
                <filter string="Manager" name="group_manager" domain="[]"
                        context="{'group_by': 'manager_id'}"/>
                <filter string="Date" name="group_date" domain="[]"
                        context="{'group_by': 'request_date'}"/>
            </search>
        </field>
    </record>
</odoo>
