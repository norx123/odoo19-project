<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================================
         APPROVAL DASHBOARD
         ============================================================ -->

    <!-- Dashboard Action -->
    <record id="action_approval_dashboard" model="ir.actions.client">
        <field name="name">Approval Dashboard</field>
        <field name="tag">approvals.dashboard</field>
    </record>

    <!-- Advance Salary Action (for New Request button from dashboard) -->
    <record id="action_advance_salary_new" model="ir.actions.act_window">
        <field name="name">Advance Salary</field>
        <field name="res_model">approvals.advance.salary</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new Advance Salary request.
            </p>
        </field>
    </record>

    <!-- Loan Request Action -->
    <record id="action_loan_request_new" model="ir.actions.act_window">
        <field name="name">Request for Loan</field>
        <field name="res_model">approvals.loan.request</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new Loan Request.
            </p>
        </field>
    </record>

    <!-- Resignation Action -->
    <record id="action_resignation_new" model="ir.actions.act_window">
        <field name="name">Employee Resignation</field>
        <field name="res_model">approvals.resignation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new Resignation request.
            </p>
        </field>
    </record>

    <!-- Travel Request Action -->
    <record id="action_travel_request_new" model="ir.actions.act_window">
        <field name="name">Travel Request</field>
        <field name="res_model">approvals.travel.request</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new Travel Request.
            </p>
        </field>
    </record>
</odoo>
