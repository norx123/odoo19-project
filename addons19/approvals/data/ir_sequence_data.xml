<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Sequence for Advance Salary -->
    <record id="seq_approvals_advance_salary" model="ir.sequence">
        <field name="name">Advance Salary Request</field>
        <field name="code">approvals.advance.salary</field>
        <field name="prefix">ADV/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence for Loan Request -->
    <record id="seq_approvals_loan_request" model="ir.sequence">
        <field name="name">Loan Request</field>
        <field name="code">approvals.loan.request</field>
        <field name="prefix">LOAN/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence for Resignation -->
    <record id="seq_approvals_resignation" model="ir.sequence">
        <field name="name">Resignation</field>
        <field name="code">approvals.resignation</field>
        <field name="prefix">RES/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence for Travel Request -->
    <record id="seq_approvals_travel_request" model="ir.sequence">
        <field name="name">Travel Request</field>
        <field name="code">approvals.travel.request</field>
        <field name="prefix">TRV/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence for Early Logout Gate Pass -->
    <record id="seq_approvals_early_gate_pass" model="ir.sequence">
        <field name="name">Early Logout Gate Pass</field>
        <field name="code">approvals.early.gate.pass</field>
        <field name="prefix">GP/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
