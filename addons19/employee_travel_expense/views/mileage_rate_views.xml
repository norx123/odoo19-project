<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== MILEAGE RATE MASTER ===================== -->

    <record id="view_mileage_rate_form" model="ir.ui.view">
        <field name="name">travel.mileage.rate.form</field>
        <field name="model">travel.mileage.rate</field>
        <field name="arch" type="xml">
            <form string="Mileage Rate">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Bike Petrol Rate 2024"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Rate Configuration">
                            <field name="vehicle_type"/>
                            <field name="fuel_type"/>
                            <field name="rate_per_km" string="Rate Per KM (₹)"/>
                        </group>
                        <group string="Validity">
                            <field name="effective_from"/>
                            <field name="effective_to"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mileage_rate_list" model="ir.ui.view">
        <field name="name">travel.mileage.rate.list</field>
        <field name="model">travel.mileage.rate</field>
        <field name="arch" type="xml">
            <list string="Mileage Rates" editable="bottom">
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="fuel_type"/>
                <field name="rate_per_km" string="Rate/KM (₹)"/>
                <field name="effective_from"/>
                <field name="effective_to"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_mileage_rate" model="ir.actions.act_window">
        <field name="name">Mileage Rate Master</field>
        <field name="res_model">travel.mileage.rate</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create mileage rates for different vehicle types!
            </p>
        </field>
    </record>

</odoo>
