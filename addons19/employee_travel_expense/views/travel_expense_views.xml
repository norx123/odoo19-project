<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         MILEAGE RATE — small inline form for Configuration
    ============================================================ -->

    <record id="view_mileage_rate_list" model="ir.ui.view">
        <field name="name">travel.mileage.rate.list</field>
        <field name="model">travel.mileage.rate</field>
        <field name="arch" type="xml">
            <list string="Mileage Rates" editable="bottom">
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="fuel_type"/>
                <field name="rate_per_km" string="Rate/KM (Rs.)"/>
                <field name="effective_from"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_mileage_rate_form" model="ir.ui.view">
        <field name="name">travel.mileage.rate.form</field>
        <field name="model">travel.mileage.rate</field>
        <field name="arch" type="xml">
            <form string="Mileage Rate">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="vehicle_type"/>
                            <field name="fuel_type"/>
                        </group>
                        <group>
                            <field name="rate_per_km" string="Rate Per KM (Rs.)"/>
                            <field name="effective_from"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mileage_rate" model="ir.actions.act_window">
        <field name="name">Mileage Rate</field>
        <field name="res_model">travel.mileage.rate</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============================================================
         MAIN TRAVEL EXPENSE FORM
    ============================================================ -->

    <record id="view_travel_expense_form" model="ir.ui.view">
        <field name="name">travel.expense.form</field>
        <field name="model">travel.expense</field>
        <field name="arch" type="xml">
            <form string="Travel Expense">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                        class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_send_for_approval" string="Send for Approval"
                        type="object" class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_approve" string="Approve" type="object"
                        class="btn-success" invisible="state != 'waiting'"/>
                    <button name="action_mark_paid" string="Mark as Paid" type="object"
                        class="btn-success" invisible="state != 'approved'"/>
                    <button name="action_refuse" string="Refuse" type="object"
                        class="btn-danger" invisible="state not in ['submitted','waiting']"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                        invisible="state not in ['refused','submitted']"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,submitted,waiting,approved,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Reference"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Type selector prominently at top -->
                    <group>
                        <field name="expense_type" widget="radio" readonly="state != 'draft'"/>
                    </group>

                    <!-- Employee Info -->
                    <group string="Employee Information">
                        <group>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="department_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="employee_phone" readonly="1"/>
                            <field name="employee_email" readonly="1"/>
                        </group>
                    </group>

                    <!-- Period -->
                    <group string="Trip Period">
                        <group>
                            <field name="date_from" readonly="state != 'draft'"/>
                            <field name="date_to" readonly="state != 'draft'"/>
                            <field name="destination" invisible="expense_type == 'local'"
                                readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="purpose" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <!-- Approvers -->
                    <group string="Approvers">
                        <field name="approver_ids" widget="many2many_tags"
                            options="{'no_create': True}" readonly="state != 'draft'"/>
                        <field name="current_approver_id" readonly="1"
                            invisible="state not in ['waiting']"/>
                    </group>

                    <notebook>

                        <!-- ===== LOCAL TRAVEL TAB ===== -->
                        <page string="Local Travel Details" name="local_travel"
                            invisible="expense_type != 'local'">
                            <field name="local_line_ids" readonly="state != 'draft'">
                                <list editable="bottom" string="Travel Lines">
                                    <field name="date"/>
                                    <field name="start_location" string="From"/>
                                    <field name="end_location" string="To"/>
                                    <field name="description"/>
                                    <field name="travel_mode"/>
                                    <field name="vehicle_id"
                                        invisible="travel_mode != 'self_vehicle'"
                                        required="travel_mode == 'self_vehicle'"/>
                                    <field name="odometer_start"
                                        invisible="travel_mode != 'self_vehicle'"/>
                                    <field name="odometer_end"
                                        invisible="travel_mode != 'self_vehicle'"/>
                                    <field name="mileage_km" string="KM"/>
                                    <field name="mileage_rate_id" string="Rate"
                                        invisible="travel_mode != 'self_vehicle'"/>
                                    <field name="rate_per_km" string="Rs./KM" optional="show"/>
                                    <field name="reimbursement_total" string="Amount (Rs.)"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_km" string="Total KM" readonly="1"/>
                                <field name="local_total" string="Total Amount (Rs.)"
                                    class="oe_subtotal_footer_separator" readonly="1"/>
                            </group>
                        </page>

                        <!-- ===== JOURNEY TAB (OUTSTATION) ===== -->
                        <page string="Journey" name="journey"
                            invisible="expense_type != 'outstation'">
                            <field name="journey_ids" readonly="state != 'draft'">
                                <list editable="bottom" string="Journey">
                                    <field name="date"/>
                                    <field name="from_location" string="From"/>
                                    <field name="to_location" string="To"/>
                                    <field name="description"/>
                                    <field name="vehicle_type" string="Mode"/>
                                    <field name="amount" string="Amount (Rs.)"/>
                                    <field name="bill" widget="binary" optional="show"
                                        string="Bill"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="journey_total" string="Journey Total (Rs.)"
                                    class="oe_subtotal_footer_separator" readonly="1"/>
                            </group>
                        </page>

                        <!-- ===== MEAL TAB (OUTSTATION) ===== -->
                        <page string="Meals" name="meals"
                            invisible="expense_type != 'outstation'">
                            <field name="meal_ids" readonly="state != 'draft'">
                                <list editable="bottom" string="Meals">
                                    <field name="date"/>
                                    <field name="meal_type"/>
                                    <field name="place"/>
                                    <field name="description"/>
                                    <field name="amount" string="Amount (Rs.)"/>
                                    <field name="bill" widget="binary" optional="show"
                                        string="Bill"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="meal_total" string="Meal Total (Rs.)"
                                    class="oe_subtotal_footer_separator" readonly="1"/>
                            </group>
                        </page>

                        <!-- ===== GIFT TAB (OUTSTATION) ===== -->
                        <page string="Gift / Entertainment" name="gifts"
                            invisible="expense_type != 'outstation'">
                            <field name="gift_ids" readonly="state != 'draft'">
                                <list editable="bottom" string="Gifts">
                                    <field name="date"/>
                                    <field name="gift_item" string="Gift / Item"/>
                                    <field name="recipient"/>
                                    <field name="description"/>
                                    <field name="amount" string="Amount (Rs.)"/>
                                    <field name="bill" widget="binary" optional="show"
                                        string="Bill"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="gift_total" string="Gift Total (Rs.)"
                                    class="oe_subtotal_footer_separator" readonly="1"/>
                            </group>
                        </page>

                        <!-- ===== OUTSTATION GRAND TOTAL ===== -->
                        <page string="Summary" name="summary"
                            invisible="expense_type != 'outstation'">
                            <group class="oe_subtotal_footer">
                                <field name="journey_total" string="Journey Total (Rs.)" readonly="1"/>
                                <field name="meal_total" string="Meal Total (Rs.)" readonly="1"/>
                                <field name="gift_total" string="Gift Total (Rs.)" readonly="1"/>
                                <field name="grand_total" string="Grand Total (Rs.)"
                                    class="oe_subtotal_footer_separator" readonly="1"/>
                            </group>
                        </page>

                        <!-- ===== REMARKS ===== -->
                        <page string="Remarks" name="remarks">
                            <field name="notes" placeholder="Additional remarks..."/>
                        </page>

                    </notebook>

                    <!-- Grand total at bottom (always visible) -->
                    <group class="oe_subtotal_footer">
                        <field name="grand_total" string="Grand Total (Rs.)"
                            class="oe_subtotal_footer_separator" readonly="1"/>
                    </group>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_travel_expense_list" model="ir.ui.view">
        <field name="name">travel.expense.list</field>
        <field name="model">travel.expense</field>
        <field name="arch" type="xml">
            <list string="Travel Expenses"
                decoration-info="state == 'draft'"
                decoration-warning="state == 'waiting'"
                decoration-success="state in ('approved','paid')"
                decoration-danger="state == 'refused'">
                <field name="name"/>
                <field name="expense_type"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="destination" optional="show"/>
                <field name="grand_total" string="Amount (Rs.)"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_travel_expense_search" model="ir.ui.view">
        <field name="name">travel.expense.search</field>
        <field name="model">travel.expense</field>
        <field name="arch" type="xml">
            <search string="Search Travel Expenses">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <separator/>
                <filter string="My Expenses" name="my_expenses"
                    domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="Local Travel" name="local"
                    domain="[('expense_type', '=', 'local')]"/>
                <filter string="Outstation" name="outstation"
                    domain="[('expense_type', '=', 'outstation')]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Waiting Approval" name="waiting"
                    domain="[('state', '=', 'waiting')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <separator/>
                <filter string="Group by Employee" name="by_emp"
                    context="{'group_by': 'employee_id'}"/>
                <filter string="Group by Type" name="by_type"
                    context="{'group_by': 'expense_type'}"/>
                <filter string="Group by Status" name="by_state"
                    context="{'group_by': 'state'}"/>
                <filter string="Group by Month" name="by_month"
                    context="{'group_by': 'date_from:month'}"/>
            </search>
        </field>
    </record>

    <!-- ACTIONS -->
    <record id="action_travel_expense_my" model="ir.actions.act_window">
        <field name="name">My Travel Expenses</field>
        <field name="res_model">travel.expense</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_travel_expense_search"/>
        <field name="context">{'search_default_my_expenses': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Apna pehla travel expense submit karein!
            </p>
        </field>
    </record>

    <record id="action_travel_expense_all" model="ir.actions.act_window">
        <field name="name">All Travel Expenses</field>
        <field name="res_model">travel.expense</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_travel_expense_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Koi bhi travel expense record nahi mila.
            </p>
        </field>
    </record>

</odoo>
