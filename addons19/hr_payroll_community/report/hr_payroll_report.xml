<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Report action for Contribution Register Report-->
    <record id="contribution_register_action" model="ir.actions.report">
        <field name="name">Contribution Register PDF</field>
        <field name="model">hr.contribution.register</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_payroll_community.report_contributionregister</field>
        <field name="report_file">hr_payroll_community.report_contributionregister</field>
    </record>

    <!--Report action for Payslip Details Report (Action menu)-->
    <record id="hr_payslip_report_action" model="ir.actions.report">
        <field name="name">Payslip Details</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="binding_model_id" ref="model_hr_payslip"/>
        <field name="report_name">hr_payroll_community.report_payslipdetails</field>
        <field name="report_file">hr_payroll_community.report_payslipdetails</field>
        <field name="print_report_name">('Payslip - %s' % (object.employee_id.name))</field>
    </record>

    <!--Dedicated Print Payslip button action-->
    <record id="hr_payslip_print_action" model="ir.actions.report">
        <field name="name">Print Payslip</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_payroll_community.report_payslipdetails</field>
        <field name="report_file">hr_payroll_community.report_payslipdetails</field>
        <field name="print_report_name">('Payslip - %s - %s' % (object.employee_id.name, object.date_from.strftime('%B %Y') if object.date_from else ''))</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>
    <!-- ══ BULK ACTION BUTTONS IN LIST VIEW ══ -->

    <!-- Cancel selected payslips (Waiting/Done/Paid → Cancel) -->
    <record id="action_bulk_cancel_payslips" model="ir.actions.server">
        <field name="name">Cancel</field>
        <field name="model_id" ref="model_hr_payslip"/>
        <field name="binding_model_id" ref="model_hr_payslip"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_bulk_cancel()</field>
    </record>

    <!-- Set to Draft selected payslips (Cancel → Draft) -->
    <record id="action_bulk_draft_payslips" model="ir.actions.server">
        <field name="name">Set to Draft</field>
        <field name="model_id" ref="model_hr_payslip"/>
        <field name="binding_model_id" ref="model_hr_payslip"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_bulk_set_to_draft()</field>
    </record>

    <!-- Confirm selected payslips (Draft/Waiting → Done) -->
    <record id="action_bulk_confirm_payslips" model="ir.actions.server">
        <field name="name">Confirm</field>
        <field name="model_id" ref="model_hr_payslip"/>
        <field name="binding_model_id" ref="model_hr_payslip"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_bulk_confirm()</field>
    </record>

</odoo>
