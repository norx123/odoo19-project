<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_hr_salary_attachment_tree" model="ir.ui.view">
        <field name="name">hr.salary.attachment.tree</field>
        <field name="model">hr.salary.attachment</field>
        <field name="arch" type="xml">
            <list string="Salary Attachments">
                <field name="employee_id"/>
                <field name="description"/>
                <field name="type"/>
                <field name="payslip_amount" sum="Total"/>
                <field name="start_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hr_salary_attachment_form" model="ir.ui.view">
        <field name="name">hr.salary.attachment.form</field>
        <field name="model">hr.salary.attachment</field>
        <field name="arch" type="xml">
            <form string="Salary Attachment">
                <header>
                    <button name="mark_as_completed" type="object"
                            string="Mark as Completed"
                            class="btn-primary"
                            invisible="state != 'running'"/>

                    <button name="cancel" type="object"
                            string="Cancel"
                            class="btn-secondary"
                            invisible="state != 'running'"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="running,completed,cancelled"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="employee_id" required="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="description" required="1"/>
                            <field name="type" required="1"/>
                            <field name="start_date" required="1"/>
                            <field name="end_date"/>
                        </group>

                        <group>
                            <field name="payslip_amount" widget="monetary"
                                   options="{'currency_field': 'company_currency_id'}"/>
                            <field name="total_amount" widget="monetary"
                                   options="{'currency_field': 'company_currency_id'}"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_salary_attachment" model="ir.actions.act_window">
        <field name="name">Salary Attachments</field>
        <field name="res_model">hr.salary.attachment</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_hr_salary_attachment_tree"/>
    </record>

</odoo>