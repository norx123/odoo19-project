<odoo>
    <record id="view_employee_form_inherit_education" model="ir.ui.view">
        <field name="name">hr.employee.form.education</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='resume']" position="after">
                <page string="Past Work Profile">
                    <field name="education_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="institute"/>
                            <field name="organization"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="percentage"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
