<odoo>
    <record id="view_employee_form_tax_docs" model="ir.ui.view">
        <field name="name">hr.employee.tax.docs</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Tax Deduction Docs">
                    <group string="SECTION 80C">
                        <field name="epf_file"/>
                        <field name="epf_amount"/>
                        <field name="life_insurance_file"/>
                        <field name="life_insurance_amount"/>
                        <field name="elss_file"/>
                        <field name="elss_amount"/>
                    </group>
                    <group string="SECTION 80D">
                        <field name="health_insurance_file"/>
                        <field name="policy_copy"/>
                        <field name="payment_proof"/>
                    </group>
                    <group string="HRA">
                        <field name="rent_receipt"/>
                        <field name="rent_agreement"/>
                        <field name="landlord_pan"/>
                        <field name="total_rent"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>