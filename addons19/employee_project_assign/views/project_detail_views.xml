<odoo>
    <record id="view_project_detail_tree" model="ir.ui.view">
        <field name="name">project.detail.tree</field>
        <field name="model">project.detail</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer"/>
                <field name="function"/>
            </list>
        </field>
    </record>

    <record id="view_project_detail_form" model="ir.ui.view">
        <field name="name">project.detail.form</field>
        <field name="model">project.detail</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="customer"/>
                        <field name="function"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_project_detail" model="ir.actions.act_window">
        <field name="name">Project Details</field>
        <field name="res_model">project.detail</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_project_detail_root"
              name="Project Details"
              parent="hr.menu_hr_root"
              action="action_project_detail"/>
</odoo>
