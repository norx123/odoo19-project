<odoo>
    <record id="view_employee_salary_custom" model="ir.ui.view">
        <field name="name">employee.salary.custom</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Salary Components">
                    <group string="CTC">
                        <field name="x_annual_ctc"/>
                        <field name="x_monthly_ctc"/>
                        <field name="x_monthly_gross"/>
                    </group>
                    <group string="Earnings" col="4">
                        <field name="x_basic"/>
                        <field name="x_basic_percent"/>
                        <field name="x_hra"/>
                        <field name="x_hra_percent"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
