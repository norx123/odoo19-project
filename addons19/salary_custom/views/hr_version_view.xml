<odoo>
    <record id="view_hr_version_salary_custom" model="ir.ui.view">
        <field name="name">hr.version.salary.custom</field>
        <field name="model">hr.version</field>
        <field name="arch" type="xml">
            <form string="Salary Structure">
                <sheet>
                    <group string="CTC">
                        <field name="x_annual_ctc"/>
                        <field name="x_monthly_ctc"/>
                        <field name="x_monthly_gross"/>
                    </group>
                    <group string="Earnings" col="4">
                        <field name="x_basic"/>
                        <field name="x_basic_percent"/>
                        <field name="x_hra"/>
                        <field name="x_hra_percent"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
