<odoo>
    <record id="view_education_list" model="ir.ui.view">
        <field name="name">education.history.list</field>
        <field name="model">education.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="institute"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="percentage"/>
            </list>
        </field>
    </record>

    <record id="view_education_form" model="ir.ui.view">
        <field name="name">education.history.form</field>
        <field name="model">education.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="institute"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="percentage"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_education_history" model="ir.actions.act_window">
        <field name="name">Education History</field>
        <field name="res_model">education.history</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_education_root" name="Education"/>
    <menuitem id="menu_education_history" name="Education History" parent="menu_education_root" action="action_education_history"/>
</odoo>
