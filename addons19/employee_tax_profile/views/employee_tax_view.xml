<odoo>
    <record id="view_employee_form_tax" model="ir.ui.view">
        <field name="name">employee.form.tax</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">

                <page string="Tax Deduction Documents">
                    <group>
                        <group>
                            <field name="hra_bill"/>
                            <field name="pf_employee"/>
                            <field name="house_loan"/>
                            <field name="tuition_fees"/>
                        </group>
                        <group>
                            <field name="sukanya"/>
                            <field name="health_insurance"/>
                            <field name="nps"/>
                            <field name="preventive_health"/>
                        </group>
                    </group>
                </page>

                <page string="Form 12B">
                    <group>
                        <field name="previous_employer"/>
                        <field name="previous_salary"/>
                        <field name="previous_tax"/>
                    </group>
                </page>

                <page string="Tax Sheet">
                    <group string="Monthly Salary">
                        <group>
                            <field name="basic_apr"/>
                            <field name="basic_may"/>
                            <field name="basic_jun"/>
                        </group>
                        <group>
                            <field name="hra_apr"/>
                            <field name="hra_may"/>
                            <field name="hra_jun"/>
                        </group>
                        <group>
                            <field name="special_apr"/>
                            <field name="special_may"/>
                            <field name="special_jun"/>
                        </group>
                    </group>

                    <group string="Summary">
                        <field name="gross_salary"/>
                        <field name="total_tax"/>
                    </group>
                </page>

            </xpath>
        </field>
    </record>
</odoo>
