<odoo>
    <record id="view_employee_salary" model="ir.ui.view">
        <field name="name">hr.employee.salary</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Payroll">
                    <group>
                        <field name="basic"/>
                        <field name="hra"/>
                        <field name="pf_employee"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>