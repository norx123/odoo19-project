<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="HrDashboardMain">
        <div class="oh_dashboards">
            <div class="container-fluid o_hr_dashboard">
                <t t-if="this.state.login_employee">
                    <t t-if="this.state.is_manager == true">
                        <t t-call="LoginEmployeeDetails"/>
                        <t t-call="ManagerDashboard"/>
                        <t t-call="ManagerExtendedDashboard"/>
                        <t t-call="EmployeeDashboard"/>
                    </t>
                    <t t-else="">
                        <t t-call="LoginEmployeeDetails"/>
                        <t t-call="EmployeeDashboard"/>
                    </t>
                </t>
            </div>
        </div>
    </t>

    <!-- LoginEmployeeDetails - Section removed as per requirement
         (Employee profile, Payslips, Timesheets, Contracts, Broad Factor, Check In all removed) -->
    <t t-name="LoginEmployeeDetails">
        <link rel="stylesheet" href="/hrms_dashboard/static/src/css/dashboard.css"/>
    </t>

    <!-- ManagerDashboard - Removed Monthly Leave Analysis, Monthly Join/Resign Analysis, Attrition Rate -->
    <t t-name="ManagerDashboard">
        <div class="employee_dashboard_main"/>
    </t>

    <!-- ===== NEW: ManagerExtendedDashboard ===== -->
    <t t-name="ManagerExtendedDashboard">
        <div class="oh_manager_extended_dashboard">

            <!-- ── SUMMARY STAT CARDS ── -->
            <div class="row main-section oh-mgr-stat-row">
                <div class="col-sm-12 col-lg-12">
                    <div class="oh-mgr-stat-cards">
                        <div class="oh-mgr-stat-card oh-stat-blue oh-clickable" t-on-click="open_today_checkins">
                            <div class="oh-mgr-stat-icon"><i class="fa fa-users"/></div>
                            <div class="oh-mgr-stat-info">
                                <span class="oh-mgr-stat-num"><t t-esc="this.state.mgr_data.stats and this.state.mgr_data.stats.checkin_count or 0"/></span>
                                <span class="oh-mgr-stat-label">Today's Check-In</span>
                            </div>
                        </div>
                        <div class="oh-mgr-stat-card oh-stat-orange oh-clickable" t-on-click="open_on_leave_today">
                            <div class="oh-mgr-stat-icon"><i class="fa fa-plane"/></div>
                            <div class="oh-mgr-stat-info">
                                <span class="oh-mgr-stat-num"><t t-esc="this.state.mgr_data.stats and this.state.mgr_data.stats.on_leave_count or 0"/></span>
                                <span class="oh-mgr-stat-label">On Leave Today</span>
                            </div>
                        </div>
                        <div class="oh-mgr-stat-card oh-stat-yellow oh-clickable" t-on-click="open_pending_leave_requests">
                            <div class="oh-mgr-stat-icon"><i class="fa fa-clock-o"/></div>
                            <div class="oh-mgr-stat-info">
                                <span class="oh-mgr-stat-num"><t t-esc="this.state.mgr_data.stats and this.state.mgr_data.stats.pending_leave_count or 0"/></span>
                                <span class="oh-mgr-stat-label">Pending Leave Requests</span>
                            </div>
                        </div>
                        <div class="oh-mgr-stat-card oh-stat-red oh-clickable" t-on-click="open_resignations">
                            <div class="oh-mgr-stat-icon"><i class="fa fa-sign-out"/></div>
                            <div class="oh-mgr-stat-info">
                                <span class="oh-mgr-stat-num"><t t-esc="this.state.mgr_data.stats and this.state.mgr_data.stats.resignation_count or 0"/></span>
                                <span class="oh-mgr-stat-label">Resignations</span>
                            </div>
                        </div>
                        <div class="oh-mgr-stat-card oh-stat-green oh-clickable" t-on-click="open_new_joiners">
                            <div class="oh-mgr-stat-icon"><i class="fa fa-user-plus"/></div>
                            <div class="oh-mgr-stat-info">
                                <span class="oh-mgr-stat-num"><t t-esc="this.state.mgr_data.stats and this.state.mgr_data.stats.new_joiner_count or 0"/></span>
                                <span class="oh-mgr-stat-label">New Joiners (Month)</span>
                            </div>
                        </div>
                        <div class="oh-mgr-stat-card oh-stat-purple oh-clickable" t-on-click="open_monthly_expenses">
                            <div class="oh-mgr-stat-icon"><i class="fa fa-inr"/></div>
                            <div class="oh-mgr-stat-info">
                                <span class="oh-mgr-stat-num">
                                    <t t-esc="this.state.mgr_data.stats ? Math.round(this.state.mgr_data.stats.expense_total) : 0"/>
                                </span>
                                <span class="oh-mgr-stat-label">Expenses (Month) ₹</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── ROW 1: TODAY CHECK-IN + TODAY ON LEAVE ── -->
            <div class="row main-section">

                <!-- Today's Check-In table -->
                <div class="col-sm-12 col-lg-6">
                    <div class="oh-card text-color oh-clickable" t-on-click="open_today_checkins">
                        <div class="oh-card-body pb-0">
                            <p class="stat_head" style="padding:0;">
                                <i class="fa fa-sign-in" style="color:#208cc2;margin-right:6px;"/>
                                Checked In Today
                                <span class="oh-badge oh-badge-blue">
                                    <t t-esc="this.state.mgr_data.today_checkins ? this.state.mgr_data.today_checkins.length : 0"/>
                                </span>
                            </p>
                        </div>
                        <div class="oh-mgr-table-wrap">
                            <table class="oh-mgr-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Employee</th>
                                        <th>Department</th>
                                        <th>Check-In</th>
                                        <th>Check-Out</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="this.state.mgr_data.today_checkins and this.state.mgr_data.today_checkins.length > 0">
                                        <tr t-foreach="this.state.mgr_data.today_checkins"
                                            t-as="row" t-key="row_index">
                                            <td><t t-esc="row_index + 1"/></td>
                                            <td class="oh-emp-name"><t t-esc="row.name"/></td>
                                            <td><t t-esc="row.dept"/></td>
                                            <td class="oh-time-in"><t t-esc="row.check_in_time"/></td>
                                            <td class="oh-time-out"><t t-esc="row.check_out_time"/></td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <tr><td colspan="5" class="oh-empty-row">No check-ins yet</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Currently On Leave -->
                <div class="col-sm-12 col-lg-6">
                    <div class="oh-card text-color oh-clickable" t-on-click="open_on_leave_today">
                        <div class="oh-card-body pb-0">
                            <p class="stat_head" style="padding:0;">
                                <i class="fa fa-plane" style="color:#f65337;margin-right:6px;"/>
                                Currently On Leave
                                <span class="oh-badge oh-badge-red">
                                    <t t-esc="this.state.mgr_data.on_leave_today ? this.state.mgr_data.on_leave_today.length : 0"/>
                                </span>
                            </p>
                        </div>
                        <div class="oh-mgr-table-wrap">
                            <table class="oh-mgr-table">
                                <thead>
                                    <tr>
                                        <th>Employee</th>
                                        <th>Department</th>
                                        <th>Leave Type</th>
                                        <th>From</th>
                                        <th>To</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="this.state.mgr_data.on_leave_today and this.state.mgr_data.on_leave_today.length > 0">
                                        <tr t-foreach="this.state.mgr_data.on_leave_today"
                                            t-as="row" t-key="row_index">
                                            <td class="oh-emp-name"><t t-esc="row.name"/></td>
                                            <td><t t-esc="row.dept"/></td>
                                            <td><t t-esc="row.leave_type"/></td>
                                            <td><t t-esc="row.from_date"/></td>
                                            <td><t t-esc="row.to_date"/></td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <tr><td colspan="5" class="oh-empty-row">No one is on leave today</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── ROW 2: EXPENSES + PENDING LEAVE REQUESTS ── -->
            <div class="row main-section">

                <!-- Monthly Expenses -->
                <div class="col-sm-12 col-lg-6">
                    <div class="oh-card text-color oh-clickable" t-on-click="open_monthly_expenses">
                        <div class="oh-card-body pb-0">
                            <p class="stat_head" style="padding:0;">
                                <i class="fa fa-inr" style="color:#8e559e;margin-right:6px;"/>
                                This Month's Expenses
                                <span class="oh-badge oh-badge-purple">
                                    <t t-esc="this.state.mgr_data.monthly_expenses ? this.state.mgr_data.monthly_expenses.length : 0"/>
                                </span>
                            </p>
                        </div>
                        <div class="oh-mgr-table-wrap">
                            <table class="oh-mgr-table">
                                <thead>
                                    <tr>
                                        <th>Employee</th>
                                        <th>Subject</th>
                                        <th>Amount (₹)</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="this.state.mgr_data.monthly_expenses and this.state.mgr_data.monthly_expenses.length > 0">
                                        <tr t-foreach="this.state.mgr_data.monthly_expenses"
                                            t-as="row" t-key="row_index">
                                            <td class="oh-emp-name"><t t-esc="row.name"/></td>
                                            <td><t t-esc="row.subject"/></td>
                                            <td class="oh-amount"><t t-esc="row.amount"/></td>
                                            <td><t t-esc="row.date"/></td>
                                            <td>
                                                <span t-attf-class="oh-state-badge oh-state-#{row.state.toLowerCase().replace(' ','-')}">
                                                    <t t-esc="row.state"/>
                                                </span>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <tr><td colspan="5" class="oh-empty-row">No expenses submitted this month</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Pending Leave Requests -->
                <div class="col-sm-12 col-lg-6">
                    <div class="oh-card text-color oh-clickable" t-on-click="open_pending_leave_requests">
                        <div class="oh-card-body pb-0">
                            <p class="stat_head" style="padding:0;">
                                <i class="fa fa-list-alt" style="color:#ffa433;margin-right:6px;"/>
                                Pending Leave Requests
                                <span class="oh-badge oh-badge-yellow">
                                    <t t-esc="this.state.mgr_data.pending_leave_requests ? this.state.mgr_data.pending_leave_requests.length : 0"/>
                                </span>
                            </p>
                        </div>
                        <div class="oh-mgr-table-wrap">
                            <table class="oh-mgr-table">
                                <thead>
                                    <tr>
                                        <th>Employee</th>
                                        <th>Leave Type</th>
                                        <th>From</th>
                                        <th>To</th>
                                        <th>Days</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="this.state.mgr_data.pending_leave_requests and this.state.mgr_data.pending_leave_requests.length > 0">
                                        <tr t-foreach="this.state.mgr_data.pending_leave_requests"
                                            t-as="row" t-key="row.id">
                                            <td class="oh-emp-name"><t t-esc="row.employee"/></td>
                                            <td><t t-esc="row.leave_type"/></td>
                                            <td><t t-esc="row.from_date"/></td>
                                            <td><t t-esc="row.to_date"/></td>
                                            <td><t t-esc="row.days"/></td>
                                            <td>
                                                <span class="oh-state-badge oh-state-pending">
                                                    <t t-esc="row.state"/>
                                                </span>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <tr><td colspan="6" class="oh-empty-row">No pending leave requests</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── ROW 3: RESIGNATIONS + NEW JOINERS ── -->
            <div class="row main-section">

                <!-- Resignations -->
                <div class="col-sm-12 col-lg-6">
                    <div class="oh-card text-color oh-clickable" t-on-click="open_resignations">
                        <div class="oh-card-body pb-0">
                            <p class="stat_head" style="padding:0;">
                                <i class="fa fa-sign-out" style="color:#cf3650;margin-right:6px;"/>
                                Resignations (Last 3 Months)
                                <span class="oh-badge oh-badge-red">
                                    <t t-esc="this.state.mgr_data.resignations ? this.state.mgr_data.resignations.length : 0"/>
                                </span>
                            </p>
                        </div>
                        <div class="oh-mgr-table-wrap">
                            <table class="oh-mgr-table">
                                <thead>
                                    <tr>
                                        <th>Employee</th>
                                        <th>Department</th>
                                        <th>Designation</th>
                                        <th>Resign Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="this.state.mgr_data.resignations and this.state.mgr_data.resignations.length > 0">
                                        <tr t-foreach="this.state.mgr_data.resignations"
                                            t-as="row" t-key="row_index">
                                            <td class="oh-emp-name"><t t-esc="row.name"/></td>
                                            <td><t t-esc="row.dept"/></td>
                                            <td><t t-esc="row.job"/></td>
                                            <td class="oh-resign-date"><t t-esc="row.resign_date"/></td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <tr><td colspan="4" class="oh-empty-row">No resignations</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- New Joiners This Month -->
                <div class="col-sm-12 col-lg-6">
                    <div class="oh-card text-color oh-clickable" t-on-click="open_new_joiners">
                        <div class="oh-card-body pb-0">
                            <p class="stat_head" style="padding:0;">
                                <i class="fa fa-user-plus" style="color:#659d4e;margin-right:6px;"/>
                                New Joiners This Month
                                <span class="oh-badge oh-badge-green">
                                    <t t-esc="this.state.mgr_data.new_joiners ? this.state.mgr_data.new_joiners.length : 0"/>
                                </span>
                            </p>
                        </div>
                        <div class="oh-mgr-table-wrap">
                            <table class="oh-mgr-table">
                                <thead>
                                    <tr>
                                        <th>Employee</th>
                                        <th>Department</th>
                                        <th>Designation</th>
                                        <th>Joining Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="this.state.mgr_data.new_joiners and this.state.mgr_data.new_joiners.length > 0">
                                        <tr t-foreach="this.state.mgr_data.new_joiners"
                                            t-as="row" t-key="row_index">
                                            <td class="oh-emp-name"><t t-esc="row.name"/></td>
                                            <td><t t-esc="row.dept"/></td>
                                            <td><t t-esc="row.job"/></td>
                                            <td class="oh-join-date"><t t-esc="row.joining_date"/></td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <tr><td colspan="4" class="oh-empty-row">No new joiners this month</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── ROW 4: DEPARTMENT ANALYSIS BAR CHART ── -->
            <div class="row main-section">
                <div class="col-sm-12 col-lg-12">
                    <div class="oh-card text-color oh-clickable" t-on-click="open_departments">
                        <div class="oh-card-body pb-0">
                            <p class="stat-head" style="padding:0;">
                                <i class="fa fa-building" style="color:#4d6cb1;margin-right:6px;"/>
                                Department-wise Employee Analysis
                            </p>
                        </div>
                        <div class="oh-dept-bar-wrap" t-ref="dept_bar_wrap">
                            <canvas id="deptBarChart" style="width:100%;max-height:300px;"/>
                        </div>
                        <!-- Department table below chart -->
                        <div class="oh-mgr-table-wrap" style="margin-top:12px;">
                            <table class="oh-mgr-table">
                                <thead>
                                    <tr>
                                        <th>Department</th>
                                        <th>Employee Count</th>
                                        <th>% of Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="this.state.mgr_data.dept_employee_count and this.state.mgr_data.dept_employee_count.length > 0">
                                        <tr t-foreach="this.state.mgr_data.dept_employee_count"
                                            t-as="row" t-key="row_index">
                                            <td class="oh-emp-name"><t t-esc="row.dept"/></td>
                                            <td><t t-esc="row.count"/></td>
                                            <td>
                                                <t t-esc="this.state.mgr_data.total_employees ?
                                                    Math.round((row.count / this.state.mgr_data.total_employees) * 100) : 0"/>%
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <tr><td colspan="3" class="oh-empty-row">No department data available</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </t>

    <!-- EmployeeDashboard - Only Upcoming Birthdays / Upcoming Events / Announcements -->
    <t t-name="EmployeeDashboard">
        <div class="row main-section">
            <div class="col-md-6 col-lg-4">
                <div class="hr_notification oh-clickable" t-on-click="open_birthdays">
                    <div class="hr_notification-head">Upcoming Birthdays</div>
                    <div class="col-xs-12 text-align">
                        <t t-if="this.state.employee_birthday and this.state.employee_birthday.length > 0">
                            <t t-foreach="this.state.employee_birthday" t-as="employee" t-key="employee['id']">
                                <div class="col-sm-12 col-lg-12 birth_emp"
                                     t-att-style="employee['is_birthday'] ? 'background: #3e6282;' : ''">
                                    <div class="text-color">
                                        <div class="media">
                                            <a href="#" style="float: left;padding-right: 6%; pointer-events: none; cursor: default;padding-left:6%">
                                                <img class="align-self-center birth_img" alt=""
                                                     t-attf-src="/web/image?model=hr.employee&amp;id={{employee['id']}}&amp;field=image_1920"/>
                                            </a>
                                            <div class="media-body">
                                                <h2 class="text-color display-6"
                                                    t-att-style="employee['is_birthday'] ? 'color: white; font-weight:500' : ''">
                                                    <t t-esc="employee['name']"/>
                                                </h2>
                                                <p t-att-style="employee['is_birthday'] ? 'color: white; font-weight:500' : ''">
                                                    <t t-esc="employee['birthday']"/>
                                                </p>
                                                <t t-if="employee['is_birthday']">
                                                    <span class="birthday">Happy Birthday..!! 🎁</span>
                                                </t>
                                                <t t-if="employee['days']">
                                                    <span class="days_left"><t t-esc="employee['days']"/> Days Left</span>
                                                </t>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <div class="text-center" style="padding: 20px; color: #6c757d;">
                                <div style="font-size: 48px; margin-bottom: 10px;">🎂</div>
                                <h4 style="margin-bottom: 8px; color: #495057;">No Upcoming Birthdays</h4>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="col-xs-12 hr_notification oh-clickable" style="padding: 0;" t-on-click="open_events">
                    <div class="col-xs-12" style="padding:0;">
                        <div class="hr_notification-head">Upcoming Events</div>
                    </div>
                    <div class="col-xs-12 text-align">
                        <t t-if="this.state.upcoming_events and this.state.upcoming_events.length > 0">
                            <t t-foreach="this.state.upcoming_events" t-as="event" t-key="event['id']">
                                <div class="col-sm-12 col-lg-12" style="padding:0;">
                                    <div class="text-color">
                                        <div class="media">
                                            <div class="media-body">
                                                <h2 class="text-color display-6" style="font-size: 15px;">
                                                    <t t-esc="event['name']"/>
                                                </h2>
                                                <p>Date: <t t-esc="event['date_begin']"/> - <t t-esc="event['date_end']"/></p>
                                                <p>Venue: <t t-esc="event['address_id'] and event['address_id'][1] or 'Online'"/></p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <div class="text-center" style="padding: 20px; color: #6c757d;">
                                <div style="font-size: 48px; margin-bottom: 10px;">📅</div>
                                <h4 style="margin-bottom: 8px; color: #495057;">No Upcoming Events</h4>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
            <div class="col-md-12 col-lg-4">
                <div class="col-xs-12 hr_notification oh-clickable" style="padding: 0;" t-on-click="open_announcements">
                    <div class="col-xs-12" style="padding:0;">
                        <div class="hr_notification-head">Announcements</div>
                    </div>
                    <div class="col-xs-12 text-align">
                        <t t-if="this.state.announcements and this.state.announcements.length > 0">
                            <t t-foreach="this.state.announcements" t-as="announcement" t-key="announcement">
                                <div class="col-sm-12 col-lg-12" style="padding:0;">
                                    <div class="text-color">
                                        <div class="media">
                                            <div class="media-body">
                                                <h2 class="text-color display-6" style="font-size: 15px;">
                                                    <t t-esc="announcement['announcement_reason']"/>
                                                </h2>
                                                <p>Date: <t t-esc="announcement['date_start']"/> --- <t t-esc="announcement['date_end']"/></p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <div class="text-center" style="padding: 20px; color: #6c757d;">
                                <div style="font-size: 48px; margin-bottom: 10px;">📢</div>
                                <h4 style="margin-bottom: 8px; color: #495057;">No Announcements</h4>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <t t-name="EmployeeWarning">
        <div>
            <p>Error: Could not find employee linked to user</p>
            <p>Please contact system admin for the setup</p>
        </div>
    </t>
</templates>
