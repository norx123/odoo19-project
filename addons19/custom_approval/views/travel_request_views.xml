<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================================
         TRAVEL REQUEST VIEWS
         ============================================================ -->

    <!-- Form View -->
    <record id="view_travel_request_form" model="ir.ui.view">
        <field name="name">custom.travel.request.form</field>
        <field name="model">custom.travel.request</field>
        <field name="arch" type="xml">
            <form string="Travel Request">
                <header>
                    <button name="action_submit" string="Submit"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager,hr.group_hr_user"/>
                    <button name="action_refuse" string="Refuse"
                            type="object"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager,hr.group_hr_user"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state not in ('draft', 'submitted')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('refused', 'cancel')"
                            groups="hr.group_hr_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Employee Information">
                            <field name="employee_id"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="department_id" readonly="1"/>
                            <field name="request_date"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="company_id"
                                   readonly="state in ('approved', 'refused', 'cancel')"
                                   groups="base.group_multi_company"/>
                        </group>
                        <group string="Travel Details">
                            <field name="travel_from"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="travel_to"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="travel_mode"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="departure_date"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="return_date"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="duration_days" readonly="1"/>
                        </group>
                    </group>
                    <group string="Purpose of Travel">
                        <field name="purpose_of_travel" nolabel="1"
                               placeholder="Describe the business purpose of this travel..."
                               readonly="state in ('approved', 'refused', 'cancel')"/>
                    </group>
                    <group string="Hotel Information">
                        <group>
                            <field name="hotel_required"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="hotel_name"
                                   invisible="hotel_required == False"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                        </group>
                        <group>
                            <field name="check_in_date"
                                   invisible="hotel_required == False"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="check_out_date"
                                   invisible="hotel_required == False"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                        </group>
                    </group>
                    <group>
                        <group string="Budget">
                            <field name="estimated_budget"
                                   readonly="state in ('approved', 'refused', 'cancel')"/>
                            <field name="currency_id"
                                   readonly="state in ('approved', 'refused', 'cancel')"
                                   groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Approver(s)" name="approvers">
                            <field name="approver_ids"
                                   readonly="state in ('approved', 'refused', 'cancel')">
                                <list editable="bottom">
                                    <field name="approver_id" string="Approver"/>
                                    <field name="required" string="Required"/>
                                    <field name="status" string="Status" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_travel_request_list" model="ir.ui.view">
        <field name="name">custom.travel.request.list</field>
        <field name="model">custom.travel.request</field>
        <field name="arch" type="xml">
            <list string="Travel Requests"
                  decoration-success="state == 'approved'"
                  decoration-warning="state == 'submitted'"
                  decoration-danger="state == 'refused'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="travel_from"/>
                <field name="travel_to"/>
                <field name="departure_date"/>
                <field name="return_date"/>
                <field name="duration_days"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'submitted'"
                       decoration-danger="state == 'refused'"
                       decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_travel_request_search" model="ir.ui.view">
        <field name="name">custom.travel.request.search</field>
        <field name="model">custom.travel.request</field>
        <field name="arch" type="xml">
            <search string="Search Travel Requests">
                <field name="name" string="Reference"/>
                <field name="employee_id"/>
                <field name="travel_from"/>
                <field name="travel_to"/>
                <filter string="My Requests" name="my_requests"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft"
                        domain="[('state','=','draft')]"/>
                <filter string="Submitted" name="submitted"
                        domain="[('state','=','submitted')]"/>
                <filter string="Approved" name="approved"
                        domain="[('state','=','approved')]"/>
                <filter string="Refused" name="refused"
                        domain="[('state','=','refused')]"/>
                <separator/>
                <filter string="Employee" name="group_employee" domain="[]"
                        context="{'group_by': 'employee_id'}"/>
                <filter string="Department" name="group_dept" domain="[]"
                        context="{'group_by': 'department_id'}"/>
                <filter string="Departure Date" name="group_departure" domain="[]"
                        context="{'group_by': 'departure_date'}"/>
            </search>
        </field>
    </record>
</odoo>
