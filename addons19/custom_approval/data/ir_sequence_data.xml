<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Sequence for Advance Salary -->
    <record id="seq_advance_salary" model="ir.sequence">
        <field name="name">Advance Salary</field>
        <field name="code">custom.advance.salary</field>
        <field name="prefix">ADV/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence for Loan Request -->
    <record id="seq_loan_request" model="ir.sequence">
        <field name="name">Loan Request</field>
        <field name="code">custom.loan.request</field>
        <field name="prefix">LOAN/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence for Resignation -->
    <record id="seq_resignation" model="ir.sequence">
        <field name="name">Employee Resignation</field>
        <field name="code">custom.resignation</field>
        <field name="prefix">RES/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence for Travel Request -->
    <record id="seq_travel_request" model="ir.sequence">
        <field name="name">Travel Request</field>
        <field name="code">custom.travel.request</field>
        <field name="prefix">TRV/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
