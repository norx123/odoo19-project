            </xpath>
            <xpath expr="//field[@name='bonus_percent']/following-sibling::span[1]" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <!-- ============================================================ -->
            <!-- HIDE: Gratuity fields                                         -->
