<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="assets_backend" inherit_id="web.assets_backend" name="Norx Backend Assets">
        <xpath expr="." position="inside">
            <link rel="stylesheet" type="text/css" href="/norx_theme/static/src/css/norx_theme.css"/>
        </xpath>
    </template>

    <template id="assets_frontend" inherit_id="web.assets_frontend" name="Norx Frontend Assets">
        <xpath expr="." position="inside">
            <link rel="stylesheet" type="text/css" href="/norx_theme/static/src/css/norx_theme.css"/>
        </xpath>
    </template>

</odoo>
