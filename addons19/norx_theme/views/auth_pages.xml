<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="login_layout_norx" inherit_id="web.login_layout" name="Norx Auth Footer">

        <!-- Remove Odoo's default "Powered by Odoo" link -->
        <xpath expr="//a[contains(@href, 'odoo.com')]" position="replace">
            <a class="text-muted" href="#">Powered by <span>Norx ERP</span></a>
        </xpath>

    </template>

</odoo>
