<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="hr_salary_attachment_view_list" model="ir.ui.view">
        <field name="name">hr.payroll.salary.attachment.list</field>
        <field name="model">hr.payroll.salary.attachment</field>
        <field name="arch" type="xml">
            <list string="Salary Attachments"
                  decoration-success="state == 'completed'"
                  decoration-muted="state == 'cancelled'">
                <field name="employee_id"/>
                <field name="description"/>
                <field name="other_input_type_id"/>
                <field name="date_start"/>
                <field name="date_end" optional="show"/>
                <field name="monthly_amount"/>
                <field name="total_amount" optional="show"/>
                <field name="negative_value"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'completed'"
                       decoration-warning="state == 'running'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="hr_salary_attachment_view_form" model="ir.ui.view">
        <field name="name">hr.payroll.salary.attachment.form</field>
        <field name="model">hr.payroll.salary.attachment</field>
        <field name="arch" type="xml">
            <form string="Salary Attachment">
                <header>
                    <button name="action_mark_completed"
                            string="Mark as Completed"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'running'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state != 'running'"/>
                    <button name="action_reset_running"
                            string="Reset to Running"
                            type="object"
                            invisible="state == 'running'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="running,completed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group string="Employee and Type">
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="description"/>
                            <field name="other_input_type_id" options="{'no_create': True}"/>
                            <field name="negative_value"/>
                        </group>
                        <group string="Amount and Period">
                            <field name="date_start"/>
                            <field name="no_end_date"/>
                            <field name="date_end" invisible="no_end_date == True"/>
                            <field name="monthly_amount"/>
                            <field name="total_amount"/>
                        </group>
                    </group>
                    <group string="Supporting Document">
                        <field name="document" widget="binary" filename="document_filename" string="Upload File"/>
                        <field name="document_filename" invisible="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="hr_salary_attachment_search" model="ir.ui.view">
        <field name="name">hr.payroll.salary.attachment.search</field>
        <field name="model">hr.payroll.salary.attachment</field>
        <field name="arch" type="xml">
            <search string="Search Salary Attachments">
                <field name="employee_id"/>
                <field name="description"/>
                <field name="other_input_type_id"/>
                <filter string="Running" name="running" domain="[('state','=','running')]"/>
                <filter string="Completed" name="completed" domain="[('state','=','completed')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state','=','cancelled')]"/>
                <group>
                    <filter string="Employee" name="employee" context="{'group_by':'employee_id'}"/>
                    <filter string="Type" name="type" context="{'group_by':'other_input_type_id'}"/>
                    <filter string="Status" name="state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="hr_salary_attachment_action" model="ir.actions.act_window">
        <field name="name">Salary Attachments</field>
        <field name="res_model">hr.payroll.salary.attachment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_salary_attachment_search"/>
        <field name="context">{'search_default_running': 1}</field>
    </record>

    <!-- Menu under Payroll root -->
    <menuitem id="menu_hr_salary_attachment"
              name="Salary Attachments"
              action="hr_salary_attachment_action"
              parent="menu_hr_payroll_community_root"
              sequence="15"
              groups="hr_payroll_community.group_hr_payroll_community_user"/>
</odoo>
